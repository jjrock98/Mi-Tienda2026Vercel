{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "regions": ["gru1"],

  "headers": [
    {
      "source": "/api/webhooks/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store, no-cache" }]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ],

  "redirects": [
    { "source": "/inicio", "destination": "/",          "permanent": true },
    { "source": "/tienda", "destination": "/#catalogo", "permanent": true }
  ],

  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap" },
    { "source": "/robots.txt",  "destination": "/robots"  }
  ],

  "crons": [
  {
    "path": "/api/revalidate?secret=REVALIDATE_SECRET_TOKEN",
    "schedule": "0 3 * * *"
  }
  ],

  "functions": {
    "src/app/api/webhooks/mercadopago/route.ts": { "maxDuration": 30 },
    "src/app/api/checkout/mercadopago/route.ts": { "maxDuration": 15 },
    "src/app/api/orders/route.ts":               { "maxDuration": 15 }
  }
}
